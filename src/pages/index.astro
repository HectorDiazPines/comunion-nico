---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Comunión de Nico">
  <div class="min-h-screen flex items-center justify-center bg-cream px-0">
    <div class="text-center max-w-md">
      <p class="text-gold-light tracking-[0.3em] uppercase text-base mb-5">Primera Comunión</p>
      <h1 class="font-fantasy text-7xl md:text-8xl text-brown-dark mb-6 leading-none [text-shadow:0_2px_20px_rgba(184,134,11,0.2)]">
        Nico
      </h1>
      <p class="text-gray-warm text-xl leading-relaxed">
        Si tienes una invitación, usa el enlace que te hemos enviado para acceder.
      </p>
    </div>
  </div>
</Layout>
