---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Comunión de Nico">
  <div class="min-h-screen flex items-center justify-center bg-cream px-4">
    <div class="text-center max-w-md">
      <p class="text-gold-light tracking-[0.3em] uppercase text-sm mb-4">Primera Comunión</p>
      <h1 class="font-heading text-5xl md:text-6xl text-brown-dark mb-6">Nico</h1>
      <p class="text-gray-warm text-lg">
        Si tienes una invitación, usa el enlace que te hemos enviado para acceder.
      </p>
    </div>
  </div>
</Layout>
