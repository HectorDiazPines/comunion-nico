---
import Layout from '../layouts/Layout.astro';
import AccessDenied from '../components/AccessDenied.astro';
import mesasData from '../data/mesas.json';

const token = import.meta.env.PUBLIC_EVENT_TOKEN;
const mesas = mesasData.mesas;
---

<Layout title="Mesas — Comunión de Nicolás">
  <div id="loading" class="min-h-screen flex items-center justify-center bg-cream">
    <p class="text-gold font-heading text-3xl max-sm:text-4xl animate-pulse text-center">Cargando...</p>
  </div>
  <div id="denied" class="hidden">
    <AccessDenied />
  </div>
  <div id="content" class="hidden">
    <main>
      <header class="mesas-header">
        <p class="eyebrow">Comunión de Nicolás · 16 de mayo</p>
        <h1>Distribución de mesas</h1>
        <div class="oro-divider" aria-hidden="true">✦ ✦ ✦</div>
      </header>

      <div class="mesas-lista">
        {mesas.map((mesa) => (
          <article class={`mesa-card ${mesa.id === 'ninos' ? 'mesa-card--ninos' : ''}`}>
            <div class="fila-nombres">
              {mesa.lado1.map((nombre) => (
                <span class="chip">{nombre}</span>
              ))}
            </div>
            <div class="mesa-barra">
              <span class="mesa-nombre">{mesa.nombre}</span>
            </div>
            <div class="fila-nombres">
              {mesa.lado2.map((nombre) => (
                <span class="chip">{nombre}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </main>
  </div>
</Layout>

<script define:vars={{ token }}>
  const params = new URLSearchParams(window.location.search);
  const t = params.get("t");
  document.getElementById("loading").classList.add("hidden");
  if (t === token) {
    document.getElementById("content").classList.remove("hidden");
  } else {
    document.getElementById("denied").classList.remove("hidden");
  }
</script>

<style>
  main {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1rem 4rem;
  }

  .mesas-header {
    text-align: center;
    padding: 2.5rem 1rem 2rem;
  }

  .eyebrow {
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 0.5rem;
  }

  h1 {
    font-family: var(--font-heading);
    font-size: clamp(1.7rem, 5vw, 2.5rem);
    color: var(--color-brown-dark);
    margin: 0 0 0.8rem;
  }

  .oro-divider {
    color: var(--color-gold-lighter);
    letter-spacing: 0.5em;
    font-size: 0.65rem;
  }

  /* Lista de mesas */
  .mesas-lista {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Card de cada mesa */
  .mesa-card {
    border: 1px solid #e8d5a3;
    border-radius: 12px;
    background: #fffdf7;
    box-shadow: 0 2px 12px rgba(184, 134, 11, 0.08);
  }

  .mesa-card--ninos .mesa-barra {
    background: linear-gradient(135deg, #7ab8a0 0%, #5a9e86 100%);
  }

  /* Móvil: scroll horizontal */
  .fila-nombres {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.4rem;
    padding: 0.85rem 1rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .fila-nombres::-webkit-scrollbar {
    display: none;
  }

  /* Chip de nombre */
  .chip {
    flex-shrink: 0;
    font-family: var(--font-heading);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-brown-dark);
    background: #fef5e4;
    border: 1px solid #e8d5a3;
    border-radius: 999px;
    padding: 0.28rem 0.8rem;
    white-space: nowrap;
  }

  /* Tablet/desktop: wrap en varias filas, sin scroll */
  @media (min-width: 640px) {
    .fila-nombres {
      flex-wrap: wrap;
      justify-content: center;
      overflow-x: visible;
      padding: 0.9rem 1.2rem;
      gap: 0.5rem;
    }

    .chip {
      flex-shrink: 1;
      font-size: 0.82rem;
      padding: 0.25rem 0.75rem;
    }
  }

  /* Barra central que representa la mesa */
  .mesa-barra {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #b8860b 0%, #d4a017 100%);
    padding: 0.7rem 1rem;
  }

  .mesa-nombre {
    font-family: var(--font-heading);
    font-size: clamp(1rem, 3vw, 1.2rem);
    font-weight: 700;
    color: #fffdf7;
    letter-spacing: 0.08em;
  }
</style>
