---
import Layout from "../layouts/Layout.astro";
import AccessDenied from "../components/AccessDenied.astro";
import Hero from "../components/Hero.astro";
import Divider from "../components/Divider.astro";
import EventInfo from "../components/EventInfo.astro";
import RsvpForm from "../components/RsvpForm.astro";
import CityGuide from "../components/CityGuide.astro";
import Footer from "../components/Footer.astro";

const token = import.meta.env.PUBLIC_EVENT_TOKEN;
---

<Layout title="Comunión de Nico - Invitación">
  <!-- Loading screen -->
  <div id="loading" class="min-h-screen flex items-center justify-center bg-cream">
    <p class="text-gold font-heading text-3xl max-sm:text-4xl animate-pulse text-center">Cargando invitación...</p>
  </div>

  <!-- Access denied -->
  <div id="denied" class="hidden">
    <AccessDenied />
  </div>

  <!-- Main content -->
  <div id="content" class="hidden">
    <Hero />
    <Divider />
    <EventInfo />
    <Divider />
    <RsvpForm />
    <Divider />
    <CityGuide />
    <Divider />
    <Footer />
  </div>
</Layout>

<script define:vars={{ token }}>
  const params = new URLSearchParams(window.location.search);
  const t = params.get("t");

  const loadingEl = document.getElementById("loading");
  const deniedEl = document.getElementById("denied");
  const contentEl = document.getElementById("content");

  if (t === token) {
    loadingEl.classList.add("hidden");
    contentEl.classList.remove("hidden");
  } else {
    loadingEl.classList.add("hidden");
    deniedEl.classList.remove("hidden");
  }
</script>
