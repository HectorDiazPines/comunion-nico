---
import Layout from "../layouts/Layout.astro";
import AccessDenied from "../components/AccessDenied.astro";
import Hero from "../components/Hero.astro";
import Divider from "../components/Divider.astro";
import EventInfo from "../components/EventInfo.astro";
import RsvpForm from "../components/RsvpForm.astro";
import WeekendInfo from "../components/WeekendInfo.astro";
import CityGuide from "../components/CityGuide.astro";
import Footer from "../components/Footer.astro";

const token = import.meta.env.PUBLIC_EVENT_TOKEN;
---

<Layout title="Comunión de Nico - Invitación">
  <!-- Loading screen -->
  <div id="loading" class="min-h-screen flex items-center justify-center bg-cream">
    <p class="text-gold font-heading text-2xl animate-pulse">Cargando invitación...</p>
  </div>

  <!-- Access denied -->
  <div id="denied" class="hidden">
    <AccessDenied />
  </div>

  <!-- Main content -->
  <div id="content" class="hidden">
    <Hero />
    <Divider />
    <EventInfo />
    <Divider />
    <RsvpForm />
    <Divider />
    <WeekendInfo />
    <Divider />
    <CityGuide />
    <Divider />
    <Footer />
  </div>
</Layout>

<script define:vars={{ token }}>
  /** Parallax del hero: 0–1 mientras el bloque cruza el viewport (notorio al deslizar). */
  function initHeroParallax() {
    const hero = document.querySelector("[data-hero-parallax]");
    if (!hero || hero.dataset.parallaxReady) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const layers = hero.querySelectorAll("[data-parallax-layer]");
    if (!layers.length) return;

    hero.dataset.parallaxReady = "1";

    const maxShift = 200;

    let raf = 0;
    const tick = () => {
      raf = 0;
      const rect = hero.getBoundingClientRect();
      const vh = window.innerHeight || 1;
      const denom = vh + rect.height;
      const progress = denom <= 0 ? 0 : Math.min(1, Math.max(0, (vh - rect.top) / denom));

      layers.forEach((el) => {
        const speed = Number.parseFloat(el.dataset.parallaxSpeed ?? "0.5");
        const y = -progress * maxShift * speed;
        el.style.transform = `translate3d(0, ${y}px, 0)`;
      });
    };

    const onScrollOrResize = () => {
      if (!raf) raf = requestAnimationFrame(tick);
    };

    window.addEventListener("scroll", onScrollOrResize, { passive: true });
    window.addEventListener("resize", onScrollOrResize);
    tick();
  }

  const params = new URLSearchParams(window.location.search);
  const t = params.get("t");

  const loadingEl = document.getElementById("loading");
  const deniedEl = document.getElementById("denied");
  const contentEl = document.getElementById("content");

  if (t === token) {
    loadingEl.classList.add("hidden");
    contentEl.classList.remove("hidden");

    const startEnhancements = () => {
      initHeroParallax();

      const fadeObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -50px 0px" }
      );

      document.querySelectorAll(".fade-in-section").forEach((section) => {
        fadeObserver.observe(section);
      });
    };

    requestAnimationFrame(() => {
      requestAnimationFrame(startEnhancements);
    });
  } else {
    loadingEl.classList.add("hidden");
    deniedEl.classList.remove("hidden");
  }
</script>
