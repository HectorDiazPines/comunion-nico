---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div
  class:list={[
    "divider-fantasy flex items-center justify-center gap-3 sm:gap-4 my-12 sm:my-14 px-0",
    className,
  ]}
>
  <span class="h-px flex-1 bg-gold-lighter/90"></span>
  <span class="divider-fantasy-icon text-gold text-3xl sm:text-2xl leading-none">&#10053;</span>
  <span class="h-px flex-1 bg-gold-lighter/90"></span>
</div>
