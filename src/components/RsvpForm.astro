---
import RsvpSuccess from "./RsvpSuccess.astro";

const rawNumbers =
  import.meta.env.PUBLIC_RSVP_WHATSAPP_NUMBERS ?? import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? "";

const whatsappList = rawNumbers
  .split(",")
  .map((s) => s.replace(/\D/g, ""))
  .filter((n) => n.length >= 9);

const rsvpPhonePrimary = whatsappList[0] ?? "";
const rsvpEmail = (import.meta.env.PUBLIC_RSVP_EMAIL ?? "").trim();
const hasWhatsapp = rsvpPhonePrimary.length >= 9;
const hasEmail = rsvpEmail.includes("@");
---

<section class="py-8 fade-in-section">
  <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl text-brown-dark mb-6 sm:mb-8 text-center">
    Confirma tu asistencia
  </h2>

  <div id="rsvp-form-wrapper">
    <p class="text-gray-warm text-center mb-5 text-sm leading-relaxed">
      Rellena los datos y pulsa <strong class="text-brown-dark">Enviar</strong>.
    </p>

    {
      !hasWhatsapp && !hasEmail && (
        <p class="text-amber-800 bg-amber-50 border border-amber-200/80 rounded-lg p-3 text-sm text-center mb-5">
          Configura en .env PUBLIC_RSVP_WHATSAPP_NUMBERS o PUBLIC_RSVP_EMAIL.
        </p>
      )
    }

    <form id="rsvp-form">
      <div class="mb-4 pr-5">
        <label for="name" class="block text-sm font-medium text-brown-dark mb-1">Nombre completo</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder="Tu nombre"
          style="display:block; width:100%; height:40px; padding:0 8px; border:1px solid #f0d78c; border-radius:8px; background:#fff; font-size:14px; color:#3d260d; margin-right:1.25rem;"
        />
      </div>

      <div class="mb-4 pr-5">
        <label for="guests" class="block text-sm font-medium text-brown-dark mb-1">Número de personas</label>
        <input
          type="number"
          id="guests"
          name="guests"
          min="1"
          max="20"
          value="1"
          required
          style="display:block; width:100%; height:40px; padding:0 8px; border:1px solid #f0d78c; border-radius:8px; background:#fff; font-size:14px; color:#3d260d; margin-right:1.25rem;"
        />
      </div>

      <div class="mb-4 pr-5">
        <label for="allergies" class="block text-sm font-medium text-brown-dark mb-1">Alergias o intolerancias</label>
        <textarea
          id="allergies"
          name="allergies"
          rows="2"
          placeholder="Ninguna, celiaco, etc."
          style="display:block; width:100%; padding:8px; border:1px solid #f0d78c; border-radius:8px; background:#fff; font-size:14px; color:#3d260d; resize:none; margin-right:1.25rem;"
        ></textarea>
      </div>

      <div class="mb-4 pr-5">
        <label for="message" class="block text-sm font-medium text-brown-dark mb-1">Mensaje</label>
        <textarea
          id="message"
          name="message"
          rows="3"
          placeholder="¡Un abrazo!"
          style="display:block; width:100%; padding:8px; border:1px solid #f0d78c; border-radius:8px; background:#fff; font-size:14px; color:#3d260d; resize:none; margin-right:1.25rem;"
        ></textarea>
      </div>

      <div class="flex flex-col gap-2">
        {
          hasWhatsapp && (
            <button
              type="submit"
              id="rsvp-submit-send"
              data-channel="whatsapp"
              data-phone={rsvpPhonePrimary}
              style="border:none; outline:none;"
              class="inline-flex items-center justify-center rounded-full bg-gold px-4 h-10 min-w-[9.5rem] text-sm font-semibold text-white hover:bg-gold-light transition-colors cursor-pointer"
            >
              Enviar
            </button>
          )
        }
        {
          hasEmail && (
            <button
              type="submit"
              id="rsvp-submit-mail"
              data-channel="email"
              class:list={[
                "h-10 rounded-full text-sm font-semibold transition-colors cursor-pointer",
                hasWhatsapp
                  ? "border-2 border-gold text-gold hover:bg-gold/10"
                  : "bg-gold text-white hover:bg-gold-light",
              ]}
            >
              Enviar por correo
            </button>
          )
        }
      </div>

      <p id="rsvp-error" class="hidden text-red-600 text-center text-sm mt-3"></p>
    </form>
  </div>

  <RsvpSuccess rsvpPhone={rsvpPhonePrimary} rsvpEmail={rsvpEmail} />
</section>

<style>
  #rsvp-form input:focus,
  #rsvp-form textarea:focus {
    outline: none;
    box-shadow: 0 0 0 2px #d4a017;
  }
</style>

<script
  define:vars={{
    hasWhatsapp,
    hasEmail,
    rsvpEmail,
    rsvpPhonePrimary,
  }}
>
  function buildRsvpText(getters) {
    const name = getters.name?.trim() || "";
    const guests = String(getters.guests ?? "1");
    const allergies = getters.allergies?.trim() || "Ninguna";
    const message = getters.message?.trim() || "";

    const lines = [
      "*Comunión de Nicolás*",
      "*Confirmación de asistencia*",
      "",
      "────────────────",
      "",
      "👤 *Nombre completo*",
      name,
      "",
      "👥 *Personas*",
      `${guests} (incluido quien escribe, si aplica)`,
      "",
      "🥗 *Alergias o intolerancias*",
      allergies,
      "",
    ];

    if (message) {
      lines.push("💬 *Mensaje*", "", message, "");
    }

    lines.push("────────────────", "", "📱 Enviado desde la invitación web.");

    return lines.join("\n");
  }

  const form = document.getElementById("rsvp-form");
  const errorEl = document.getElementById("rsvp-error");
  const formWrapper = document.getElementById("rsvp-form-wrapper");
  const successEl = document.getElementById("rsvp-success");

  function showSuccess() {
    formWrapper?.classList.add("hidden");
    successEl?.classList.remove("hidden");
  }

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    errorEl?.classList.add("hidden");

    const submitter = e.submitter;
    const channel =
      submitter?.getAttribute?.("data-channel") ||
      (hasWhatsapp ? "whatsapp" : hasEmail ? "email" : "");
    let phone =
      submitter?.getAttribute?.("data-phone")?.replace(/\D/g, "") ||
      String(rsvpPhonePrimary || "").replace(/\D/g, "");

    const data = {
      name: form.querySelector("#name").value,
      guests: form.querySelector("#guests").value,
      allergies: form.querySelector("#allergies").value,
      message: form.querySelector("#message").value,
    };

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const text = buildRsvpText(data);

    if (channel === "whatsapp" && hasWhatsapp && phone) {
      const url = `https://wa.me/${phone}?text=${encodeURIComponent(text)}`;
      const opened = window.open(url, "_blank", "noopener,noreferrer");
      if (!opened) {
        errorEl.textContent = "Permite ventanas emergentes o prueba desde el móvil.";
        errorEl.classList.remove("hidden");
        return;
      }
      showSuccess();
      return;
    }

    if (channel === "email" && hasEmail) {
      const subject = encodeURIComponent("RSVP — Comunión Nicolás");
      const plain = text.replace(/\*/g, "").replace(/👤|👥|🥗|💬|📱|─/g, "").replace(/\n\n\n+/g, "\n\n");
      const body = encodeURIComponent(plain);
      window.location.href = `mailto:${rsvpEmail}?subject=${subject}&body=${body}`;
      showSuccess();
      return;
    }

    errorEl.textContent = "Falta configurar el envío.";
    errorEl.classList.remove("hidden");
  });
</script>
