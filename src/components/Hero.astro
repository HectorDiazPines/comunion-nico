---
---

<section
  data-hero-parallax
  class="relative min-h-screen min-h-[100dvh] flex flex-col items-center justify-center text-center px-4 sm:px-6 bg-cream-warm overflow-hidden"
>
  <!-- Decorative parallax: JS mueve los wrappers al hacer scroll por el hero -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <span
      class="hero-parallax-wrap top-[12%] left-[8%] sm:left-[10%]"
      data-parallax-layer
      data-parallax-speed="1"
    >
      <span class="text-gold-lighter/30 text-xl sm:text-2xl float-element block">&#10022;</span>
    </span>
    <span
      class="hero-parallax-wrap top-[18%] right-[10%] sm:right-[15%]"
      data-parallax-layer
      data-parallax-speed="0.55"
    >
      <span class="text-gold-lighter/20 text-2xl sm:text-3xl float-element-delayed block">&#10022;</span>
    </span>
    <span
      class="hero-parallax-wrap bottom-[28%] left-[6%] sm:left-[8%]"
      data-parallax-layer
      data-parallax-speed="0.35"
    >
      <span class="text-gold-lighter/25 text-lg sm:text-xl float-element block">&#10022;</span>
    </span>
    <span
      class="hero-parallax-wrap bottom-[22%] right-[8%] sm:right-[12%]"
      data-parallax-layer
      data-parallax-speed="0.55"
    >
      <span class="text-gold-lighter/30 text-xl sm:text-2xl float-element-delayed block">&#10022;</span>
    </span>
    <span
      class="hero-parallax-wrap top-[38%] right-[4%] sm:right-[5%]"
      data-parallax-layer
      data-parallax-speed="1"
    >
      <span class="text-gold-lighter/15 text-3xl sm:text-4xl float-element block">&#10022;</span>
    </span>
    <span
      class="hero-parallax-wrap top-[58%] left-[4%] sm:left-[5%]"
      data-parallax-layer
      data-parallax-speed="0.35"
    >
      <span class="text-gold-lighter/20 text-2xl sm:text-3xl float-element-delayed block">&#10022;</span>
    </span>

    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-cream/50"></div>
  </div>

  <!-- Main content -->
  <div class="relative z-10">
    <p class="text-gold-light tracking-[0.2em] sm:tracking-[0.3em] uppercase text-xs sm:text-sm mb-4 sm:mb-6">
      Estás invitado a la
    </p>
    <h1 class="font-heading text-[clamp(1.75rem,6vw,4.5rem)] sm:text-5xl md:text-7xl text-brown-dark mb-2 sm:mb-3 leading-tight">
      Primera Comunión
    </h1>
    <p class="font-heading text-[clamp(1.35rem,4.5vw,3rem)] sm:text-3xl md:text-5xl text-gold mb-6 sm:mb-8">de Nico</p>
    <div
      class="flex flex-wrap items-center justify-center gap-x-3 gap-y-2 sm:gap-4 text-gray-warm text-sm sm:text-base md:text-lg max-w-[22rem] sm:max-w-none mx-auto"
    >
      <span class="h-px w-8 sm:w-12 bg-gold-lighter shrink-0 max-sm:hidden"></span>
      <time class="text-balance" datetime="2026-05-16">Sábado, 16 de mayo de 2026</time>
      <span class="h-px w-8 sm:w-12 bg-gold-lighter shrink-0 max-sm:hidden"></span>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-[max(1.25rem,env(safe-area-inset-bottom))] sm:bottom-8 left-1/2 -translate-x-1/2 max-sm:scale-90"
  >
    <div class="scroll-indicator flex flex-col items-center gap-1.5 sm:gap-2 text-gold-light/60">
      <span class="text-[10px] sm:text-xs tracking-widest uppercase">Desliza</span>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </div>
</section>
