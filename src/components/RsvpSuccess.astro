---
interface Props {
  rsvpPhone?: string;
  rsvpEmail?: string;
}

const { rsvpPhone = "", rsvpEmail = "" } = Astro.props;
const phoneClean = rsvpPhone.replace(/\D/g, "");
const hasWa = phoneClean.length >= 9;
const hasMail = rsvpEmail.includes("@");
---

<div id="rsvp-success" class="hidden text-center py-14 px-0">
  <div class="text-7xl mb-6">&#127881;</div>
  <h3 class="font-heading text-3xl sm:text-4xl text-brown-dark mb-4">¡Listo!</h3>
  <p class="text-gray-warm text-xl mb-6 max-w-md mx-auto leading-relaxed">
    <strong class="text-brown-dark">Último paso:</strong> revisa el texto que se ha generado y confirma el envío en la
    pantalla que se haya abierto.
  </p>
  {
    hasWa && (
      <p class="text-gray-warm text-base mb-6 max-w-md mx-auto">
        <a
          href={`https://wa.me/${phoneClean}`}
          class="text-gold underline underline-offset-2"
          target="_blank"
          rel="noopener noreferrer"
        >
          Volver a abrir el envío
        </a>
        <span class="text-gray-warm"> · si no se abrió antes</span>
      </p>
    )
  }
  {
    hasMail && (
      <p class="text-gray-warm text-base mb-2">
        <a href={`mailto:${rsvpEmail}`} class="text-gold underline underline-offset-2">
          Correo
        </a>
        <span class="text-gray-warm"> · alternativa</span>
      </p>
    )
  }
</div>
