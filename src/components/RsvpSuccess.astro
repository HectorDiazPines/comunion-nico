---
interface Props {
  rsvpPhone?: string;
  rsvpEmail?: string;
}

const { rsvpPhone = "", rsvpEmail = "" } = Astro.props;
const phoneClean = rsvpPhone.replace(/\D/g, "");
const hasWa = phoneClean.length >= 9;
const hasMail = rsvpEmail.includes("@");
---

<div id="rsvp-success" class="hidden bg-cream-warm rounded-2xl px-4 py-6 sm:px-6 sm:py-8 shadow-sm text-center">
  <div class="text-5xl mb-4">&#127881;</div>
  <h3 class="font-heading text-2xl sm:text-3xl text-brown-dark mb-3">¡Listo!</h3>
  <p class="text-gray-warm text-sm sm:text-base mb-5 leading-relaxed">
    <strong class="text-brown-dark">Último paso:</strong> revisa el texto que se ha generado y confirma el envío en la
    pantalla que se haya abierto.
  </p>
  {
    hasWa && (
      <p class="text-gray-warm text-sm mb-3">
        <a
          href={`https://wa.me/${phoneClean}`}
          class="text-gold underline underline-offset-2 hover:text-gold-light"
          target="_blank"
          rel="noopener noreferrer"
        >
          Volver a abrir el envío
        </a>
        <span class="text-gray-warm/80"> · si no se abrió antes</span>
      </p>
    )
  }
  {
    hasMail && (
      <p class="text-gray-warm text-sm">
        <a href={`mailto:${rsvpEmail}`} class="text-gold underline underline-offset-2 hover:text-gold-light">
          Correo
        </a>
        <span class="text-gray-warm/80"> · alternativa</span>
      </p>
    )
  }
</div>
