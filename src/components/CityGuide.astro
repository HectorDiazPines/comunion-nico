---
const mapsSearch = (q: string) =>
  `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(q)}`;

const museums = [
  {
    title: "Museo del Puerto Fluvial de Caesaraugusta",
    query: "Museo del Puerto Fluvial de Caesaraugusta, Zaragoza",
  },
  {
    title: "Museo del Foro de Caesaraugusta",
    query: "Museo del Foro de Caesaraugusta, Zaragoza",
  },
  {
    title: "Museo de las Termas Públicas de Caesaraugusta",
    query:
      "Museo de las Termas Públicas de Caesaraugusta, C. de San Juan y San Pedro, 7, Casco Antiguo, 50001 Zaragoza",
  },
  {
    title: "Museo del Teatro Romano de Caesaraugusta",
    query: "Museo del Teatro Romano de Caesaraugusta, Zaragoza",
  },
] as const;

const basilica = {
  title: "Catedral-Basílica de Nuestra Señora del Pilar",
  query:
    "Catedral-Basílica de Nuestra Señora del Pilar, Plaza del Pilar, Casco Antiguo, 50003 Zaragoza",
} as const;

const parkings = [
  { label: "Parking Plaza del Pilar", query: "Parking Plaza del Pilar, Zaragoza" },
  { label: "Parking Ayuntamiento", query: "Parking Ayuntamiento de Zaragoza" },
] as const;
---

<section class="w-full py-2 text-center fade-in-section">
  <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl text-brown-dark mb-4 sm:mb-6">Guía de la ciudad</h2>
  <p class="text-gray-warm text-base sm:text-lg max-w-xl mx-auto mb-8 sm:mb-10 leading-relaxed">
    Cuatro museos de la Zaragoza romana en el casco Antiguo: un mismo paseo enlazando
    <strong class="text-brown-dark">puerto fluvial</strong>, <strong class="text-brown-dark">foro</strong>,
    <strong class="text-brown-dark">termas</strong> y <strong class="text-brown-dark">teatro</strong>.
    Puedes sacar <strong class="text-brown-dark">entradas para los cuatro</strong> en cualquiera de ellos.
  </p>

  <ol class="text-left max-w-xl mx-auto space-y-5 sm:space-y-6 list-decimal list-outside pl-5 sm:pl-6 marker:text-gold marker:font-heading">
    {
      museums.map((m) => (
        <li class="pl-1">
          <a
            href={mapsSearch(m.query)}
            target="_blank"
            rel="noopener noreferrer"
            class="font-heading text-gold text-lg sm:text-lg md:text-xl hover:text-gold-light underline underline-offset-4 decoration-gold-lighter/80 transition-colors"
          >
            {m.title}
          </a>
        </li>
      ))
    }
  </ol>

  <div class="mt-12 sm:mt-14 max-w-xl mx-auto text-left space-y-3">
    <h3 class="font-heading text-gold text-xl sm:text-xl text-center sm:text-left mb-2">Basílica del Pilar</h3>
    <p class="text-gray-warm text-base sm:text-lg leading-relaxed">
      También merece la pena visitar la
      <a
        href={mapsSearch(basilica.query)}
        target="_blank"
        rel="noopener noreferrer"
        class="font-heading text-gold underline underline-offset-4 decoration-gold-lighter/80 hover:text-gold-light transition-colors"
      >
        {basilica.title}
      </a>
      <span class="text-brown-dark/90"> (Plaza del Pilar, s/n, Casco Antiguo, 50003 Zaragoza).</span>
      Se puede <strong class="text-brown-dark font-medium">subir al torreón</strong> con vistas sobre la ciudad.
    </p>
  </div>

  <div class="mt-10 sm:mt-12 max-w-xl mx-auto text-left">
    <h3 class="font-heading text-gold text-xl sm:text-xl text-center sm:text-left mb-3">Aparcamiento</h3>
    <p class="text-gray-warm text-base sm:text-lg leading-relaxed mb-4">
      Junto a la <strong class="text-brown-dark font-medium">Plaza del Pilar</strong> hay
      <strong class="text-brown-dark font-medium">dos parkings seguidos</strong>, muy cómodos para acercarse
      en coche a la basílica y al resto del casco Antiguo:
    </p>
    <ul class="space-y-2.5 text-base sm:text-lg">
      {
        parkings.map((p) => (
          <li class="pl-1">
            <a
              href={mapsSearch(p.query)}
              target="_blank"
              rel="noopener noreferrer"
              class="font-heading text-gold underline underline-offset-4 decoration-gold-lighter/80 hover:text-gold-light transition-colors"
            >
              {p.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
