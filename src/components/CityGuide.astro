<section class="max-w-3xl mx-auto px-4 py-16 sm:py-20 text-center fade-in-section">
  <h2 class="font-heading text-2xl sm:text-3xl md:text-4xl text-brown-dark mb-3 sm:mb-4">Guía de la ciudad</h2>
  <p class="text-gray-warm mb-8 sm:mb-10 text-sm sm:text-base">Algunos sitios que os recomendamos si os quedáis el fin de semana</p>

  <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4 sm:gap-6 text-left">
    <!-- Dónde dormir -->
    <div class="bg-cream-warm rounded-2xl p-6 shadow-sm">
      <div class="text-3xl mb-3">&#127976;</div>
      <h3 class="font-heading text-lg text-gold mb-2">Dónde dormir</h3>
      <ul class="text-gray-warm text-sm space-y-1">
        <li>&bull; Hotel Ejemplo Centro</li>
        <li>&bull; Hostal La Plaza</li>
        <li>&bull; Apartamentos Casco Antiguo</li>
      </ul>
    </div>

    <!-- Dónde comer -->
    <div class="bg-cream-warm rounded-2xl p-6 shadow-sm">
      <div class="text-3xl mb-3">&#127860;</div>
      <h3 class="font-heading text-lg text-gold mb-2">Dónde comer</h3>
      <ul class="text-gray-warm text-sm space-y-1">
        <li>&bull; Restaurante La Tradición</li>
        <li>&bull; Bar de Tapas El Rincón</li>
        <li>&bull; Cafetería Los Arcos</li>
      </ul>
    </div>

    <!-- Qué ver -->
    <div class="bg-cream-warm rounded-2xl p-6 shadow-sm">
      <div class="text-3xl mb-3">&#128248;</div>
      <h3 class="font-heading text-lg text-gold mb-2">Qué ver</h3>
      <ul class="text-gray-warm text-sm space-y-1">
        <li>&bull; Catedral y casco antiguo</li>
        <li>&bull; Parque del Río</li>
        <li>&bull; Miradores y paseo fluvial</li>
      </ul>
    </div>
  </div>
</section>
