PUBLIC_EVENT_TOKEN=nico2026
# RSVP: primer número (34…) es el destino del botón «Enviar» (wa.me). Puedes listar más separados por coma; solo se usa el primero.
PUBLIC_RSVP_WHATSAPP_NUMBERS=34612345678
PUBLIC_RSVP_EMAIL=

# ── Mapas: todo esto es GRATIS (no son API keys de pago) ──────────────────
#
# Los botones "Cómo llegar" y "Ver en Maps" ya funcionan sin rellenar nada:
# son enlaces normales a Google Maps y no cuestan dinero.
#
# Las variables de abajo son OPCIONALES:
# • *_EMBED_URL: en maps.google.com → el lugar → Compartir → "Insertar un mapa".
#   Copias solo la URL del <iframe> (src="..."). Eso es gratuito para webs.
# • *_IMAGE_URL: una foto o captura tuya en /public, ej. /iglesia-mapa.png
#   (tampoco hace falta API; puedes dejarlas vacías).
#
PUBLIC_MAPS_CHURCH_EMBED_URL=
PUBLIC_MAPS_VENUE_EMBED_URL=
PUBLIC_MAPS_CHURCH_IMAGE_URL=
PUBLIC_MAPS_VENUE_IMAGE_URL=
